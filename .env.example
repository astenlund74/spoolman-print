# Copy this file to .env.local and set your local service URLs.
# These are only used by the Vite dev server proxy (npm run dev).
# The production Docker image uses SPOOLMAN_URL / SPOOLMANSYNC_URL env vars
# passed to the container at runtime (see docker/nginx.conf.template).

SPOOLMAN_URL=http://spoolman.local:7912
SPOOLMANSYNC_URL=http://spoolmansync.local:3000
